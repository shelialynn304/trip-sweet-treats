<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VIP Access Confirmed | Trip's Sweet Treats</title>
  <meta name="description" content="VIP access confirmed for Trip's Sweet Treats May drop. Early access before the public release." />

  <style>
    :root {
      --bg: #0b0b0f;
      --bg-2: #141419;
      --card: rgba(255, 255, 255, 0.05);
      --border: rgba(255, 255, 255, 0.08);
      --text: #f7f3ed;
      --muted: #c8c0b4;
      --gold: #f0c76a;
      --gold-2: #d6a84f;
      --shadow: 0 22px 50px rgba(0, 0, 0, 0.45);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top right, rgba(240, 199, 106, 0.12), transparent 24%),
        radial-gradient(circle at top left, rgba(255, 123, 137, 0.08), transparent 20%),
        linear-gradient(180deg, #08080b 0%, #101018 45%, #0b0b11 100%);
      line-height: 1.6;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    .container {
      width: min(92%, 1080px);
      margin: 0 auto;
    }

    .page {
      padding: 70px 0 80px;
    }

    .hero-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.03));
      border: 1px solid var(--border);
      border-radius: 32px;
      box-shadow: var(--shadow);
      padding: 40px 32px;
      text-align: center;
      margin-bottom: 26px;
      overflow: hidden;
      position: relative;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 20%, rgba(240, 199, 106, 0.12), transparent 25%),
        radial-gradient(circle at 80% 30%, rgba(240, 199, 106, 0.08), transparent 20%);
      pointer-events: none;
    }

    .hero-card > * {
      position: relative;
      z-index: 1;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 12px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(240, 199, 106, 0.12);
      border: 1px solid rgba(240, 199, 106, 0.22);
      color: var(--gold);
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    h1 {
      margin: 0 0 14px;
      font-size: clamp(2.4rem, 6vw, 4.8rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      color: #fffaf2;
    }

    .subhead {
      margin: 0 auto 18px;
      max-width: 760px;
      font-size: 1.08rem;
      color: var(--muted);
    }

    .vip-confirmed {
      display: inline-block;
      margin: 0 0 20px;
      padding: 12px 18px;
      border-radius: 999px;
      background: linear-gradient(135deg, #f0c76a 0%, #d6a84f 100%);
      color: #111;
      font-weight: 800;
      box-shadow: 0 12px 24px rgba(214, 168, 79, 0.22);
    }

    .spots-note {
      max-width: 700px;
      margin: 0 auto 24px;
      padding: 14px 18px;
      border-radius: 18px;
      background: rgba(240, 199, 106, 0.08);
      border: 1px solid rgba(240, 199, 106, 0.18);
      color: #f3ddb0;
      font-weight: 700;
    }

    .countdown-wrap {
      margin-top: 28px;
    }

    .countdown-label {
      margin: 0 0 12px;
      color: var(--gold);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.8rem;
      font-weight: 800;
    }

    .countdown {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      max-width: 720px;
      margin: 0 auto;
    }

    .time-box {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      padding: 18px 12px;
      text-align: center;
    }

    .time-box strong {
      display: block;
      font-size: clamp(1.6rem, 4vw, 2.7rem);
      line-height: 1;
      margin-bottom: 6px;
      color: #fff;
    }

    .time-box span {
      color: var(--muted);
      text-transform: uppercase;
      font-size: 0.76rem;
      letter-spacing: 0.08em;
    }

    .status-line {
      margin-top: 16px;
      color: #f3ddb0;
      font-weight: 700;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 24px;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
    }

    .card h2 {
      margin: 0 0 14px;
      font-size: clamp(1.6rem, 3vw, 2.3rem);
      line-height: 1.08;
      letter-spacing: -0.03em;
      color: #fffaf2;
    }

    .card p {
      margin: 0 0 14px;
      color: var(--muted);
    }

    .list {
      margin: 0;
      padding-left: 20px;
      color: var(--muted);
    }

    .list li + li {
      margin-top: 10px;
    }

    .highlight-box {
      margin-top: 18px;
      padding: 16px 18px;
      border-radius: 18px;
      background: rgba(240, 199, 106, 0.08);
      border: 1px solid rgba(240, 199, 106, 0.18);
      color: #f3ddb0;
      font-weight: 700;
    }

    .action-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 28px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 54px;
      padding: 0 24px;
      border-radius: 999px;
      font-weight: 800;
      transition: 0.25s ease;
      text-decoration: none;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(135deg, #f0c76a 0%, #d6a84f 100%);
      color: #111;
      box-shadow: 0 12px 24px rgba(214, 168, 79, 0.22);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 30px rgba(214, 168, 79, 0.28);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.04);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.12);
    }

    .btn-secondary:hover {
      background: rgba(255,255,255,0.08);
      transform: translateY(-1px);
    }

    .footer-note {
      text-align: center;
      margin-top: 20px;
      color: #9f978b;
      font-size: 0.95rem;
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .countdown {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 640px) {
      .page {
        padding: 40px 0 60px;
      }

      .hero-card,
      .card {
        padding: 24px 18px;
      }

      .action-row {
        flex-direction: column;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>

  <main class="page">
    <div class="container">

      <section class="hero-card">
